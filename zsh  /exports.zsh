# ─── VARIABLES DE ENTORNO ───────────────────────────────────────────────────────
export LANG=en_US.UTF-8
export WORDLISTS="/usr/share/wordlists"

# ─── GOLANG ─────────────────────────────────────────────────────────────────────
export GOPATH="$HOME/go"
