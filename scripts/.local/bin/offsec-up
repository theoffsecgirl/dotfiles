#!/bin/bash
# Raycast Script para arrancar offsec-toolbox
# Required parameters:
# @raycast.schemaVersion 1
# @raycast.title Start Offsec Toolbox
# @raycast.mode compact
# @raycast.packageName Bug Bounty
# @raycast.icon 🔐

set -e

CONTAINER_DIR="$HOME/.dotfiles/containers/debian-toolbox"

if [ ! -d "$CONTAINER_DIR" ]; then
    echo "❌ Container dir not found: $CONTAINER_DIR"
    exit 1
fi

cd "$CONTAINER_DIR"

# Check si ya está corriendo
if docker ps --format '{{.Names}}' | grep -q "offsec-toolbox"; then
    echo "✅ offsec-toolbox already running"
    exit 0
fi

# Build si no existe la imagen
if ! docker images | grep -q "debian-toolbox-offsec"; then
    echo "🔨 Building image..."
    docker compose build
fi

echo "🚀 Starting offsec-toolbox..."
docker compose up -d

echo "✅ Container ready. Use 'offsec-shell' to connect."
