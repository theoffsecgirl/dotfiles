#!/usr/bin/env bash
# claude-recon — analiza outputs de recon con Claude Code
# Uso: claude-recon <dominio>
set -euo pipefail

[[ -z "${1:-}" ]] && { echo "Uso: claude-recon <dominio>"; exit 1; }

TARGET="$1"
BASE="${HUNTING_HOME:-$HOME/hunting}/targets/$TARGET"
OUTDIR="$BASE/ai"
mkdir -p "$OUTDIR"

INPUT=$(cat <<EOF
TARGET: $TARGET

FILES:
- http/live.txt
- http/urls.txt
- js/files.txt
- fuzz/params.txt

OBJECTIVE:
- identificar activos interesantes
- detectar superficies sensibles
- priorizar hosts
- sugerir vectores de ataque

OUTPUT (JSON):
{
  "priority_hosts": [],
  "sensitive_flows": [],
  "attack_vectors": [],
  "notes": []
}
EOF
)

claude <<EOF > "$OUTDIR/recon.json"
$INPUT
EOF

echo "[+] Claude recon analysis guardado en $OUTDIR/recon.json"
