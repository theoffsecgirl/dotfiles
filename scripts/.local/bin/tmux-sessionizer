#!/usr/bin/env bash
# tmux-sessionizer — switch rápido entre proyectos con fzf
# Inspirado por ThePrimeagen
set -euo pipefail

if [[ $# -eq 1 ]]; then
  selected="$1"
else
  selected=$(find ${HUNTING_HOME:-$HOME/hunting} ${HUNTING_HOME:-$HOME/hunting}/targets ~/.dotfiles -mindepth 1 -maxdepth 1 -type d 2>/dev/null | fzf --height=40% --reverse --prompt='proyecto> ')
fi

[[ -z "${selected:-}" ]] && exit 0

selected_name=$(basename "$selected" | tr . _)

if [[ -z "${TMUX:-}" ]] && ! pgrep -x tmux >/dev/null 2>&1; then
  tmux new-session -s "$selected_name" -c "$selected"
  exit 0
fi

if ! tmux has-session -t="$selected_name" 2>/dev/null; then
  tmux new-session -ds "$selected_name" -c "$selected"
fi

if [[ -z "${TMUX:-}" ]]; then
  tmux attach-session -t "$selected_name"
else
  tmux switch-client -t "$selected_name"
fi
