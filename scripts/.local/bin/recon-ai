#!/usr/bin/env bash
set -euo pipefail

[[ -z "${1:-}" ]] && { echo "Uso: recon-ai <dominio>"; exit 1; }

TARGET="$1"
BASE="${HUNTING_HOME:-$HOME/hunting}/targets/$TARGET"
OUTDIR="$BASE/ai"
PROMPTFILE="$OUTDIR/recon.prompt.txt"
OUTFILE="$OUTDIR/recon.json"
ERRFILE="$OUTDIR/recon.claude.stderr.log"

[[ -d "$BASE" ]] || { echo "[ERR] Target no encontrado: $BASE"; exit 1; }
mkdir -p "$OUTDIR"

section() {
  local rel="$1"
  local lines="${2:-200}"
  local abs="$BASE/$rel"
  echo "===== FILE: $rel ====="
  if [[ -f "$abs" ]]; then
    sed -n "1,${lines}p" "$abs"
  else
    echo "[missing] $rel"
  fi
  echo
}

{
  cat <<EOF
Analiza este dataset de recon para bug bounty del target: $TARGET

NO expliques teoría.
NO propongas payloads.
NO hagas explotación.

Tu trabajo es FILTRAR y PRIORIZAR.

Devuelve SOLO JSON válido con este esquema:
{
  "top_hosts": [
    {
      "host": "",
      "score": 0,
      "why": [],
      "focus": []
    }
  ],
  "top_endpoints": [
    {
      "url": "",
      "score": 0,
      "why": [],
      "focus": []
    }
  ],
  "top_params": [
    {
      "name": "",
      "score": 0,
      "why": [],
      "focus": []
    }
  ],
  "discard": [
    {
      "item": "",
      "reason": ""
    }
  ]
}

Criterios de scoring:
- más score si hay auth, registration, session, redirects, business logic, partner/admin/seller flows
- menos score si son assets estáticos, documentación, bundles repetidos, image optimizers o ruido de frontend
- prioriza señales reales de bug bounty sobre volumen bruto

Dataset:
EOF
  section "http/live.txt" 200
  section "http/urls.txt" 250
  section "http/api_candidates.txt" 200
  section "js/files.txt" 200
  section "fuzz/params.txt" 200
  section "fuzz/sensitive_params.txt" 200
  section "fuzz/params_by_host.jsonl" 120
} > "$PROMPTFILE"

if ! command -v claude >/dev/null 2>&1; then
  echo "[WARN] claude no disponible. Prompt guardado en $PROMPTFILE"
  echo "[→] Pega el prompt en ChatGPT"
  exit 0
fi

if claude -p "$(cat "$PROMPTFILE")" > "$OUTFILE" 2>"$ERRFILE"; then
  echo "[+] Priorización guardada en $OUTFILE"
  echo "[+] Prompt reutilizable → $PROMPTFILE"
else
  rm -f "$OUTFILE"
  echo "[WARN] Claude no devolvió resultado usable. Revisa $ERRFILE"
  echo "[+] Prompt reutilizable → $PROMPTFILE"
  echo "[→] Pega el prompt en ChatGPT"
fi
