#!/usr/bin/env bash
set -euo pipefail

[[ -z "${1:-}" ]] && { echo "Uso: recon-ai <dominio>"; exit 1; }

TARGET="$1"
BASE="${HUNTING_HOME:-$HOME/hunting}/targets/$TARGET"
OUTDIR="$BASE/ai"
PROMPTFILE="$OUTDIR/recon.prompt.txt"
OUTFILE="$OUTDIR/recon.json"
ERRFILE="$OUTDIR/recon.claude.stderr.log"
RAWFILE="$OUTDIR/recon.raw.txt"

[[ -d "$BASE" ]] || { echo "[ERR] Target no encontrado: $BASE"; exit 1; }
mkdir -p "$OUTDIR"

section() {
  local rel="$1"
  local lines="${2:-200}"
  local abs="$BASE/$rel"
  echo "===== FILE: $rel ====="
  if [[ -f "$abs" ]]; then
    sed -n "1,${lines}p" "$abs"
  else
    echo "[missing] $rel"
  fi
  echo
}

{
  cat <<EOF2
Analiza este dataset de recon para bug bounty del target: $TARGET

NO expliques teoría.
NO propongas payloads.
NO hagas explotación.
No uses markdown. No uses bloques \`\`\`json. No añadas texto antes ni después del JSON.

Tu trabajo es FILTRAR, PRIORIZAR y REDUCIR RUIDO.

Devuelve SOLO JSON válido con este esquema:
{
  "summary": {
    "focus_order": [],
    "quick_notes": []
  },
  "top_hosts": [
    {
      "host": "",
      "score": 0,
      "why": [],
      "focus": []
    }
  ],
  "top_endpoints": [
    {
      "url": "",
      "score": 0,
      "why": [],
      "focus": []
    }
  ],
  "top_params": [
    {
      "name": "",
      "score": 0,
      "why": [],
      "focus": []
    }
  ],
  "discard": [
    {
      "item": "",
      "reason": ""
    }
  ]
}

REGLAS:
- summary.focus_order: lista ordenada de lo que debo mirar primero (máx 5 items)
- summary.quick_notes: notas cortas tipo "ignorar X", "cuidado con Y", "esto huele a Z"

Criterios de scoring:
- más score si hay auth, registration, session, redirects, business logic, partner/admin/seller flows
- menos score si son assets estáticos, documentación, bundles repetidos, image optimizers o ruido de frontend
- prioriza señales reales de bug bounty sobre volumen bruto

Heurísticas:
- prioriza flujos reales de negocio sobre volumen
- penaliza duplicados, bundles Nordic y JS repetidos
- detecta parámetros de control de flujo (go, next, redirect, path, url)
- detecta endpoints raros (background, automation, session, cross_site)

Objetivo final:
Reducir el dataset a:
- dónde mirar primero
- qué endpoints tocar
- qué parámetros tienen más valor
- qué ignorar sin perder tiempo

Dataset:
EOF2
  section "http/live.txt" 200
  section "http/urls.txt" 250
  section "http/api_candidates.txt" 200
  section "js/files.txt" 200
  section "fuzz/params.txt" 200
  section "fuzz/sensitive_params.txt" 200
  section "fuzz/params_by_host.jsonl" 120
} > "$PROMPTFILE"

if ! command -v claude >/dev/null 2>&1; then
  echo "[ERR] claude no está instalado o no está en PATH"
  echo "[+] Prompt reutilizable → $PROMPTFILE"
  exit 1
fi

OUTPUT="$(claude -p "$(cat "$PROMPTFILE")" 2>"$ERRFILE" || true)"

if [[ -z "$OUTPUT" ]]; then
  echo "[ERR] Claude no devolvió nada"
  echo "[→] Revisa $ERRFILE"
  echo "[+] Prompt reutilizable → $PROMPTFILE"
  exit 1
fi

echo "$OUTPUT" > "$RAWFILE"

JSON_EXTRACT="$(printf '%s\n' "$OUTPUT" | sed -n '/^{/,$p')"

if [[ -z "$JSON_EXTRACT" ]]; then
  echo "[ERR] No se pudo extraer JSON de la salida de Claude"
  echo "[+] Raw output → $RAWFILE"
  echo "[→] Revisa $ERRFILE"
  exit 1
fi

if ! printf '%s\n' "$JSON_EXTRACT" | jq . >/dev/null 2>&1; then
  echo "[ERR] Claude devolvió salida no JSON válida"
  echo "[+] Raw output → $RAWFILE"
  echo "[→] Revisa $ERRFILE"
  exit 1
fi

printf '%s\n' "$JSON_EXTRACT" | jq . > "$OUTFILE"
echo "[+] Priorización guardada en $OUTFILE"
