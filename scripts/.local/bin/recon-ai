#!/usr/bin/env bash
set -euo pipefail

[[ -z "${1:-}" ]] && { echo "Uso: recon-ai <dominio>"; exit 1; }
[[ -z "${OPENAI_API_KEY:-}" ]] && { echo "[ERR] Falta OPENAI_API_KEY"; exit 1; }

TARGET="$1"
BASE="${HUNTING_HOME:-$HOME/hunting}/targets/$TARGET"
OUTDIR="$BASE/ai"
PROMPTFILE="$OUTDIR/recon.prompt.txt"
OUTFILE="$OUTDIR/recon.json"

mkdir -p "$OUTDIR"

section() {
  local rel="$1"
  local lines="${2:-200}"
  local abs="$BASE/$rel"
  echo "===== FILE: $rel ====="
  if [[ -f "$abs" ]]; then
    sed -n "1,${lines}p" "$abs"
  else
    echo "[missing] $rel"
  fi
  echo
}

# -------- PROMPT --------
{
cat <<EOF2
Analiza este dataset de recon para bug bounty del target: $TARGET

NO expliques teoría.
NO propongas payloads.
NO hagas explotación.

Tu trabajo es FILTRAR, PRIORIZAR y REDUCIR RUIDO.

Devuelve SOLO JSON válido con este esquema:
{
  "summary": {
    "focus_order": [],
    "quick_notes": []
  },
  "top_hosts": [],
  "top_endpoints": [],
  "top_params": [],
  "discard": []
}

Criterios:
- prioriza auth, registration, session, redirect, partner, seller
- penaliza static, bundles, docs
- detecta params: go, next, redirect, url, path

Dataset:
EOF2
section "http/live.txt"
section "http/urls.txt"
} > "$PROMPTFILE"

# -------- CALL OPENAI --------
RESPONSE=$(curl -s https://api.openai.com/v1/chat/completions \
  -H "Authorization: Bearer $OPENAI_API_KEY" \
  -H "Content-Type: application/json" \
  -d "{
    \"model\": \"gpt-5.3\",
    \"messages\": [
      {\"role\": \"user\", \"content\": $(jq -Rs . < "$PROMPTFILE")}
    ],
    \"temperature\": 0.2
  }")

echo "$RESPONSE" | jq -r '.choices[0].message.content' > "$OUTFILE"

echo "[+] Recon AI automático → $OUTFILE"
