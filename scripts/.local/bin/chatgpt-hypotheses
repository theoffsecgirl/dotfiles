#!/usr/bin/env bash
# chatgpt-hypotheses — genera prompt listo para pegar en ChatGPT
# Uso: chatgpt-hypotheses <dominio>
set -euo pipefail

[[ -z "${1:-}" ]] && { echo "Uso: chatgpt-hypotheses <dominio>"; exit 1; }

TARGET="$1"
BASE="${HUNTING_HOME:-$HOME/Library/Mobile Documents/com~apple~CloudDocs/02_PROFESIONAL/bugbounty}/targets/$TARGET"
OUTDIR="$BASE/ai"
PROMPTFILE="$OUTDIR/hypotheses.chatgpt.prompt.txt"

[[ -d "$BASE" ]] || { echo "[ERR] Target no encontrado: $BASE"; exit 1; }
mkdir -p "$OUTDIR"

section() {
  local rel="$1"
  local lines="${2:-200}"
  local abs="$BASE/$rel"
  echo "===== FILE: $rel ====="
  if [[ -f "$abs" ]]; then
    sed -n "1,${lines}p" "$abs"
  else
    echo "[missing] $rel"
  fi
  echo
}

{
  cat <<EOF
Genera hipótesis de bug bounty para el target: $TARGET

Devuelve SOLO JSON con hipótesis priorizadas y tests claros.

Dataset:
EOF
  section "http/httpx.jsonl" 200
  section "http/api_candidates.txt" 200
  section "http/graphql.txt" 200
  section "js/files.txt" 200
  section "fuzz/params_by_host.jsonl" 200
  section "fuzz/sensitive_params.txt" 200
} > "$PROMPTFILE"

echo "[+] Prompt listo → $PROMPTFILE"
echo "[→] Abre ChatGPT y pega el contenido"
