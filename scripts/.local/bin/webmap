#!/usr/bin/env bash
# webmap — crawl de URLs JS con katana
# Uso: webmap <dominio>
# Depende de: scope (genera http/live.txt), katana, anew
set -euo pipefail

[[ -z "${1:-}" ]] && { echo "Uso: webmap <dominio>"; exit 1; }

TARGET="$1"
BASE="${HUNTING_HOME:-$HOME/hunting}/targets/$TARGET"
LIVEFILE="$BASE/http/live.txt"

if [[ ! -f "$LIVEFILE" ]]; then
  echo "[!] No se encontró $LIVEFILE"
  echo "    Ejecuta primero: scope $TARGET"
  exit 1
fi

if ! command -v katana >/dev/null 2>&1; then
  echo "[!] katana no instalado: go install github.com/projectdiscovery/katana/cmd/katana@latest"
  exit 1
fi

mkdir -p "$BASE/http" "$BASE/js"

katana -list "$LIVEFILE" -silent -jc -kf all | anew "$BASE/http/urls.txt"
grep -Ei '\.js($|\?)' "$BASE/http/urls.txt" | anew "$BASE/js/files.txt"

URL_COUNT=$(wc -l < "$BASE/http/urls.txt" | tr -d ' ')
JS_COUNT=$(wc -l < "$BASE/js/files.txt" | tr -d ' ')
echo "[+] URLs: $URL_COUNT | JS: $JS_COUNT → $BASE"
