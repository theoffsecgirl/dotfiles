#!/bin/bash
# Raycast Script para arrancar VM Kali en UTM
# Required parameters:
# @raycast.schemaVersion 1
# @raycast.title Start Kali VM
# @raycast.mode compact
# @raycast.packageName Bug Bounty
# @raycast.icon 🐉

set -e

# Nombre de la VM en UTM (ajustar según tu config)
VM_NAME="Kali"

# Verificar si UTM está instalado
if ! command -v utmctl &> /dev/null; then
    echo "❌ UTM CLI not found."
    echo "Install UTM from: https://mac.getutm.app/"
    exit 1
fi

echo "🚀 Starting Kali VM..."
utmctl start "$VM_NAME"

echo "✅ Kali VM started."
