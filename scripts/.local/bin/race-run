#!/usr/bin/env bash
# race-run — lanza N peticiones en paralelo desde un fichero HTTP raw
# Uso: race-run <request.txt> [n=20]
#
# Formato esperado de request.txt:
#   GET /endpoint HTTP/1.1
#   Host: target.com
#   Cookie: session=xxx
#   (línea en blanco)
#   body opcional
set -euo pipefail

[[ -z "${1:-}" ]] && { echo "Uso: race-run <request.txt> [n=20]"; exit 1; }
[[ ! -f "$1" ]]   && { echo "[!] Fichero no encontrado: $1"; exit 1; }

REQ_FILE="$1"
N="${2:-20}"

# Primera línea: Método + Path
REQ_LINE=$(head -1 "$REQ_FILE")
METHOD=$(awk '{print $1}' <<< "$REQ_LINE")
PATH_=$(awk '{print $2}' <<< "$REQ_LINE")

# Host
HOST=$(grep -i '^Host:' "$REQ_FILE" | head -1 | awk '{print $2}' | tr -d '\r')
[[ -z "$HOST" ]] && { echo "[!] No se encontró la cabecera Host en $REQ_FILE"; exit 1; }

# Detectar HTTPS por el puerto o convención
if [[ "$HOST" == *:443 ]]; then
  URL="https://$HOST$PATH_"
else
  URL="https://$HOST$PATH_"
fi

# Headers (todas las líneas de cabecera excepto Host y la primera)
HEADERS=()
while IFS= read -r line; do
  line="${line%$'\r'}"  # eliminar \r
  [[ -z "$line" ]] && break  # línea en blanco = fin de headers
  [[ "$line" =~ ^(GET|POST|PUT|PATCH|DELETE|HEAD) ]] && continue
  [[ "$line" =~ ^[Hh]ost: ]] && continue
  HEADERS+=("-H" "$line")
done < "$REQ_FILE"

# Body (todo lo que hay después de la línea en blanco)
BODY=$(awk 'f; /^[[:space:]]*$/{f=1}' "$REQ_FILE" | head -c 65536)

run_one() {
  if [[ -n "$BODY" ]]; then
    curl -sk -X "$METHOD" "$URL" "${HEADERS[@]}" -d "$BODY" -o /dev/null -w "%{http_code}\n"
  else
    curl -sk -X "$METHOD" "$URL" "${HEADERS[@]}" -o /dev/null -w "%{http_code}\n"
  fi
}

echo "[*] Lanzando $N peticiones contra $URL"
for _ in $(seq 1 "$N"); do
  run_one &
done
wait
echo "[+] Listo: $N requests enviadas"
