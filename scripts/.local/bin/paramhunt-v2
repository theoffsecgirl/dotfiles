#!/usr/bin/env bash
# paramhunt-v2 — soporta dominio | fichero | URL
set -euo pipefail

BASE_ROOT="${HUNTING_HOME:-$HOME/hunting}/targets"
MODE=""
TARGET=""
BASE=""
INPUT_LIST=""

resolve_input() {
  local arg="${1:-}"

  [[ -z "$arg" ]] && { echo "Uso: paramhunt-v2 <dominio|urls.txt|url>"; exit 1; }

  if [[ -f "$arg" ]]; then
    MODE="file"
    TARGET="$(basename "$arg")"
    TARGET="${TARGET%.*}"
    BASE="$BASE_ROOT/_adhoc/$TARGET"
    INPUT_LIST="$arg"
    return
  fi

  if [[ "$arg" =~ ^https?:// ]]; then
    MODE="url"
    TARGET="$(printf '%s' "$arg" | sed -E 's#https?://##; s#/.*$##; s#[^A-Za-z0-9._-]#_#g')"
    BASE="$BASE_ROOT/_adhoc/$TARGET"
    INPUT_LIST="$(mktemp)"
    printf '%s\n' "$arg" > "$INPUT_LIST"
    return
  fi

  MODE="target"
  TARGET="$arg"
  BASE="$BASE_ROOT/$TARGET"
  INPUT_LIST="$BASE/http/urls_clean.txt"
  [[ -f "$INPUT_LIST" ]] || INPUT_LIST="$BASE/http/urls.txt"
  [[ -f "$INPUT_LIST" ]] || { echo "[!] No URLs"; exit 1; }
}

resolve_input "$1"

mkdir -p "$BASE/fuzz" "$BASE/meta"

grep '=' "$INPUT_LIST" | sort -u > "$BASE/fuzz/urls_with_params.txt" || true
unfurl keys < "$BASE/fuzz/urls_with_params.txt" | sort -u > "$BASE/fuzz/params.txt" || true

echo "[+] Params → $BASE/fuzz/params.txt"
