#!/usr/bin/env bash
# paramhunt-v2 — extrae parámetros, correlaciona con URLs y marca sensibles
# Uso: paramhunt-v2 <dominio>
set -euo pipefail

[[ -z "${1:-}" ]] && { echo "Uso: paramhunt-v2 <dominio>"; exit 1; }

TARGET="$1"
BASE="${HUNTING_HOME:-$HOME/hunting}/targets/$TARGET"
URLFILE="$BASE/http/urls_clean.txt"
[[ -f "$URLFILE" ]] || URLFILE="$BASE/http/urls.txt"

[[ -f "$URLFILE" ]] || { echo "[!] No se encontró http/urls.txt o http/urls_clean.txt"; exit 1; }

for dep in python3 unfurl; do
  command -v "$dep" >/dev/null 2>&1 || { echo "[!] Falta: $dep"; exit 1; }
done

mkdir -p "$BASE/fuzz" "$BASE/meta"

unfurl keys < "$URLFILE" | sort -u > "$BASE/fuzz/params.txt"

python3 - "$URLFILE" "$BASE/fuzz/params_by_url.tsv" "$BASE/fuzz/sensitive_params.txt" "$BASE/fuzz/params_by_host.jsonl" <<'PY'
import json, sys
from urllib.parse import urlparse, parse_qsl

urlfile, out_tsv, out_sensitive, out_jsonl = sys.argv[1:5]
SENSITIVE = {
    'id','user','user_id','account','account_id','email','token','access_token',
    'redirect','return','next','url','file','filename','path','document','doc',
    'order','order_id','payment','payment_id','invoice','invoice_id','key','code'
}
rows = []
sensitive = set()
with open(urlfile, 'r', encoding='utf-8', errors='ignore') as f:
    for raw in f:
        raw = raw.strip()
        if not raw:
            continue
        parsed = urlparse(raw)
        host = parsed.netloc
        for k, _ in parse_qsl(parsed.query, keep_blank_values=True):
            rows.append((host, raw, k))
            if k.lower() in SENSITIVE or any(x in k.lower() for x in ['token','redir','return','id','user','account','file','path','order','payment']):
                sensitive.add(k)

with open(out_tsv, 'w', encoding='utf-8') as f:
    for host, url, key in rows:
        f.write(f"{host}\t{key}\t{url}\n")

with open(out_sensitive, 'w', encoding='utf-8') as f:
    for k in sorted(sensitive):
        f.write(k + '\n')

by_host = {}
for host, url, key in rows:
    by_host.setdefault(host, {'host': host, 'params': set(), 'examples': []})
    by_host[host]['params'].add(key)
    if len(by_host[host]['examples']) < 10:
        by_host[host]['examples'].append(url)

with open(out_jsonl, 'w', encoding='utf-8') as f:
    for host, item in sorted(by_host.items()):
        obj = {
            'host': host,
            'params': sorted(item['params']),
            'examples': item['examples']
        }
        f.write(json.dumps(obj, ensure_ascii=False) + '\n')
PY

jq -n \
  --arg total "$(wc -l < "$BASE/fuzz/params.txt" | tr -d ' ')" \
  --arg sensitive "$(wc -l < "$BASE/fuzz/sensitive_params.txt" | tr -d ' ')" \
  '{params_total:($total|tonumber), sensitive_params:($sensitive|tonumber)}' \
  > "$BASE/meta/paramhunt.json"

echo "[+] Parámetros únicos → $BASE/fuzz/params.txt"
echo "[+] Params por URL → $BASE/fuzz/params_by_url.tsv"
echo "[+] Params sensibles → $BASE/fuzz/sensitive_params.txt"
echo "[+] Params por host JSONL → $BASE/fuzz/params_by_host.jsonl"
