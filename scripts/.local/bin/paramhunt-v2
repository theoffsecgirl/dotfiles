#!/usr/bin/env bash
# paramhunt-v2 — soporta dominio | fichero | URL
set -euo pipefail

BASE_ROOT="${HUNTING_HOME:-$HOME/hunting}/targets"

resolve_input() {
  local arg="${1:-}"

  [[ -z "$arg" ]] && { echo "Uso: paramhunt-v2 <dominio|urls.txt|url>"; exit 1; }

  if [[ -f "$arg" ]]; then
    MODE="file"
    TARGET="$(basename "$arg")"
    TARGET="${TARGET%.*}"
    BASE="$BASE_ROOT/_adhoc/$TARGET"
    URLFILE="$arg"
    return
  fi

  if [[ "$arg" =~ ^https?:// ]]; then
    MODE="url"
    TARGET="$(printf '%s' "$arg" | sed -E 's#https?://##; s#/.*$##; s#[^A-Za-z0-9._-]#_#g')"
    BASE="$BASE_ROOT/_adhoc/$TARGET"
    URLFILE="$(mktemp)"
    printf '%s\n' "$arg" > "$URLFILE"
    return
  fi

  MODE="target"
  TARGET="$arg"
  BASE="$BASE_ROOT/$TARGET"
  URLFILE="$BASE/http/urls_clean.txt"
  [[ -f "$URLFILE" ]] || URLFILE="$BASE/http/urls.txt"
  [[ -f "$URLFILE" ]] || { echo "[!] No URLs"; exit 1; }
}

resolve_input "$1"

command -v unfurl >/dev/null 2>&1 || { echo "[!] Falta: unfurl"; exit 1; }

mkdir -p "$BASE/fuzz" "$BASE/meta"

grep '=' "$URLFILE" | sort -u > "$BASE/fuzz/urls_with_params.txt" || true
unfurl keys < "$BASE/fuzz/urls_with_params.txt" | sort -u > "$BASE/fuzz/params.txt" || true

echo "[+] Params → $BASE/fuzz/params.txt"
