#!/usr/bin/env bash
# mktarget — crea estructura de directorios para un target
# Uso: mktarget <dominio>
set -euo pipefail

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=/dev/null
source "$SCRIPT_DIR/../lib/offsec.sh"

case "${1:-}" in
  -h|--help)
    echo "Uso: mktarget <dominio>"
    echo "  Crea la estructura de directorios para un target en \$HUNTING_HOME/targets/<dominio>."
    exit 0 ;;
esac

[[ -z "${1:-}" ]] && { echo "Uso: mktarget <dominio>"; exit 1; }
_reject_flag_as_target "$1"

TARGET="$1"
BASE="${HUNTING_HOME:-$HOME/Library/Mobile Documents/com~apple~CloudDocs/02_PROFESIONAL/bugbounty}/targets/$TARGET"

mkdir -p "$BASE"/{recon,http,fuzz,js,in,out,tmp,burp,notes,reports,loot,meta}

if [[ ! -f "$BASE/in/resolvers.txt" ]]; then
  cat > "$BASE/in/resolvers.txt" <<'EOF'
1.1.1.1
1.0.0.1
8.8.8.8
8.8.4.4
9.9.9.9
149.112.112.112
EOF
fi

if [[ ! -f "$BASE/notes/summary.md" ]]; then
  cat > "$BASE/notes/summary.md" <<EOF
# $TARGET

## Scope
- Programa:
- Tipo: Bug Bounty / VDP
- Wildcards:
- Excluded:

## Recon
- Subs totales:
- Hosts vivos:

## Hallazgos
- [ ]
EOF
fi

echo "[+] Target creado: $BASE"
echo "[→] Siguiente paso: scope $TARGET"
