#!/usr/bin/env bash
set -euo pipefail

[[ -z "${1:-}" ]] && { echo "Uso: hypotheses-ai <dominio>"; exit 1; }

TARGET="$1"
BASE="${HUNTING_HOME:-$HOME/hunting}/targets/$TARGET"
OUTDIR="$BASE/ai"
PROMPTFILE="$OUTDIR/hypotheses.prompt.txt"
OUTFILE="$OUTDIR/hypotheses.json"
ERRFILE="$OUTDIR/hypotheses.claude.stderr.log"
RAWFILE="$OUTDIR/hypotheses.raw.txt"

[[ -d "$BASE" ]] || { echo "[ERR] Target no encontrado: $BASE"; exit 1; }
mkdir -p "$OUTDIR"

section() {
  local rel="$1"
  local lines="${2:-200}"
  local abs="$BASE/$rel"
  echo "===== FILE: $rel ====="
  if [[ -f "$abs" ]]; then
    sed -n "1,${lines}p" "$abs"
  else
    echo "[missing] $rel"
  fi
  echo
}

{
  cat <<EOF2
Genera hipótesis de bug bounty para el target: $TARGET

NO expliques teoría general.
NO inventes findings.
NO hagas explotación automática.
No uses markdown. No uses bloques \`\`\`json. No añadas texto antes ni después del JSON.

Tu trabajo es convertir la priorización en hipótesis accionables.

Devuelve SOLO JSON válido con este esquema:
{
  "summary": {
    "best_bets": [],
    "quick_notes": []
  },
  "hypotheses": [
    {
      "title": "",
      "score": 0,
      "type": "",
      "host": "",
      "endpoint": "",
      "params": [],
      "why": [],
      "checks": [],
      "signals": [],
      "impact": ""
    }
  ]
}

REGLAS:
- summary.best_bets: máximo 5 líneas tipo "host → vector"
- summary.quick_notes: notas cortas operativas

TIPOS permitidos:
- Open Redirect
- User Enumeration
- Business Logic
- Auth Bypass
- Session Handling
- Authorization
- SSRF
- File Read
- Workflow Abuse

Criterios:
- prioriza hipótesis con señal real del dataset
- premia registration/login/session/partner/seller/redirect
- penaliza assets, docs, bundles repetidos y ruido frontend

Dataset:
EOF2
  section "http/api_candidates.txt" 200
  section "http/graphql.txt" 120
  section "fuzz/sensitive_params.txt" 120
  section "fuzz/params_by_host.jsonl" 200
  section "ai/recon.json" 200
  section "http/urls.txt" 250
} > "$PROMPTFILE"

if ! command -v claude >/dev/null 2>&1; then
  echo "[ERR] claude no está instalado o no está en PATH"
  echo "[+] Prompt reutilizable → $PROMPTFILE"
  exit 1
fi

OUTPUT="$(claude -p "$(cat "$PROMPTFILE")" 2>"$ERRFILE" || true)"

if [[ -z "$OUTPUT" ]]; then
  echo "[ERR] Claude no devolvió nada"
  echo "[→] Revisa $ERRFILE"
  echo "[+] Prompt reutilizable → $PROMPTFILE"
  exit 1
fi

echo "$OUTPUT" > "$RAWFILE"

JSON_EXTRACT="$(printf '%s\n' "$OUTPUT" | sed -n '/^{/,$p')"

if [[ -z "$JSON_EXTRACT" ]]; then
  echo "[ERR] No se pudo extraer JSON de la salida de Claude"
  echo "[+] Raw output → $RAWFILE"
  echo "[→] Revisa $ERRFILE"
  exit 1
fi

if ! printf '%s\n' "$JSON_EXTRACT" | jq . >/dev/null 2>&1; then
  echo "[ERR] Claude devolvió salida no JSON válida"
  echo "[+] Raw output → $RAWFILE"
  echo "[→] Revisa $ERRFILE"
  exit 1
fi

printf '%s\n' "$JSON_EXTRACT" | jq . > "$OUTFILE"
echo "[+] Hipótesis guardadas en $OUTFILE"
