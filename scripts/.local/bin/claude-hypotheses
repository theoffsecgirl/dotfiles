#!/usr/bin/env bash
# claude-hypotheses — genera hipótesis de ataque desde dataset de recon
# Uso: claude-hypotheses <dominio>
set -euo pipefail

[[ -z "${1:-}" ]] && { echo "Uso: claude-hypotheses <dominio>"; exit 1; }

TARGET="$1"
BASE="${HUNTING_HOME:-$HOME/Library/Mobile Documents/com~apple~CloudDocs/02_PROFESIONAL/bugbounty}/targets/$TARGET"
OUTDIR="$BASE/ai"
mkdir -p "$OUTDIR"

INPUT=$(cat <<EOF
TARGET: $TARGET

FILES:
- http/httpx.jsonl
- http/api_candidates.txt
- http/graphql.txt
- js/files.txt
- fuzz/params_by_host.jsonl
- fuzz/sensitive_params.txt

OBJECTIVE:
- generar hipótesis reales de bug bounty
- priorizar por impacto y probabilidad
- evitar ruido y falsos positivos

OUTPUT (JSON):
{
  "hypotheses": [
    {
      "title": "",
      "type": "IDOR | Auth Bypass | Business Logic | SSRF | Open Redirect | File Read | Race Condition",
      "endpoint": "",
      "params": [],
      "why": "",
      "preconditions": "",
      "test": "",
      "expected_signal": "",
      "impact": "",
      "confidence": "high|medium|low"
    }
  ]
}
EOF
)

claude <<EOF > "$OUTDIR/hypotheses.json"
$INPUT
EOF

echo "[+] Hipótesis guardadas en $OUTDIR/hypotheses.json"
