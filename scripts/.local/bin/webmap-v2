#!/usr/bin/env bash
# webmap-v2 — crawling enriquecido + separación de endpoints
# Uso: webmap-v2 <dominio>
set -euo pipefail

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
LIB_DIR="$(cd -- "$SCRIPT_DIR/../lib" && pwd)"
# shellcheck source=/dev/null
source "$LIB_DIR/offsec.sh"

[[ -z "${1:-}" ]] && die "Uso: webmap-v2 <dominio>"

TARGET="$1"
BASE="${HUNTING_HOME:-$HOME/hunting}/targets/$TARGET"
LIVEFILE="$BASE/http/live.txt"

[[ -f "$LIVEFILE" ]] || die "Ejecuta primero scope-v2 $TARGET"

need_cmd katana anew grep jq
ensure_dir "$BASE/http" "$BASE/js" "$BASE/meta"

: > "$BASE/http/urls.txt"
: > "$BASE/http/urls_clean.txt"
: > "$BASE/http/api_candidates.txt"
: > "$BASE/http/graphql.txt"
: > "$BASE/js/files.txt"

katana \
  -list "$LIVEFILE" \
  -silent \
  -jc \
  -kf all \
  2>/dev/null \
  | tee "$BASE/http/katana.raw" \
  | anew "$BASE/http/urls.txt" >/dev/null || true

grep -Ei '\.js($|\?)' "$BASE/http/urls.txt" | anew "$BASE/js/files.txt" >/dev/null || true
grep -Ei '/api(/|$)|/v[0-9]+/|graphql|rest|swagger|openapi|/rpc(/|$)|/query($|[/?])|/mutation($|[/?])|/internal(/|$)' "$BASE/http/urls.txt" | anew "$BASE/http/api_candidates.txt" >/dev/null || true
grep -Ei 'graphql' "$BASE/http/urls.txt" | anew "$BASE/http/graphql.txt" >/dev/null || true
grep -Evi '\.(png|jpg|jpeg|gif|svg|css|woff|woff2|ttf|ico)($|\?)' "$BASE/http/urls.txt" > "$BASE/http/urls_clean.txt" || true

urls_count="$(count_lines_safe "$BASE/http/urls.txt")"
js_count="$(count_lines_safe "$BASE/js/files.txt")"
api_count="$(count_lines_safe "$BASE/http/api_candidates.txt")"

jq -n \
  --arg urls "$urls_count" \
  --arg js "$js_count" \
  --arg api "$api_count" \
  '{urls:($urls|tonumber), js:($js|tonumber), api_candidates:($api|tonumber)}' \
  > "$BASE/meta/webmap.json"

log_ok "URLs totales: $urls_count"
log_ok "JS: $js_count"
log_ok "API candidates: $api_count"
log_ok "Raw crawl → $BASE/http/katana.raw"
