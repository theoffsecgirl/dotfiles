#!/usr/bin/env bash
# webmap-v2 — crawling enriquecido + separación de endpoints
# Uso: webmap-v2 <dominio|lista.txt|url>
set -euo pipefail

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
LIB_DIR="$(cd -- "$SCRIPT_DIR/../lib" && pwd)"
# shellcheck source=/dev/null
source "$LIB_DIR/offsec.sh"

trap 'printf "[!] Error en linea %d — %s\n" "$LINENO" "$BASH_COMMAND" >&2
      printf "[!] Si falló una tool externa, revisa sus flags con -h o -version\n" >&2' ERR

case "${1:-}" in
  -h|--help)
    echo "Uso: webmap-v2 <dominio|lista.txt|url>  (o usa el wrapper estable: webmap <...>)"
    echo "  Crawling con katana + separación de endpoints JS/API/GraphQL."
    echo "  Anterior: scope <dominio>   Siguiente: paramhunt-v2 <dominio>"
    echo
    echo "Variables opcionales para controlar carga:"
    echo "  KATANA_DEPTH=2"
    echo "  KATANA_CONCURRENCY=15"
    echo "  KATANA_PARALLELISM=15"
    echo "  KATANA_TIMEOUT=10"
    echo "  KATANA_RATE_LIMIT=5"
    exit 0 ;;
esac

TMP_LIVEFILE=""

cleanup() {
  [[ -n "${TMP_LIVEFILE:-}" && -f "$TMP_LIVEFILE" ]] && rm -f "$TMP_LIVEFILE"
}

trap cleanup EXIT

resolve_input() {
  local arg="${1:-}"

  [[ -z "$arg" ]] && die "Uso: webmap-v2 <dominio|lista.txt|url>"

  if [[ -f "$arg" ]]; then
    INPUT_MODE="file"
    INPUT_SOURCE="$arg"
    TARGET="$(basename "$arg")"
    TARGET="${TARGET%.*}"
    BASE="${HUNTING_HOME:-$HOME/hunting}/targets/_adhoc/$TARGET"
    LIVEFILE="$arg"
    return
  fi

  if [[ "$arg" =~ ^https?:// ]]; then
    INPUT_MODE="url"
    INPUT_SOURCE="$arg"
    TARGET="$(printf '%s' "$arg" | sed -E 's#https?://##; s#/.*$##; s#[^A-Za-z0-9._-]#_#g')"
    BASE="${HUNTING_HOME:-$HOME/hunting}/targets/_adhoc/$TARGET"
    TMP_LIVEFILE="$(mktemp)"
    LIVEFILE="$TMP_LIVEFILE"
    printf '%s\n' "$arg" > "$LIVEFILE"
    return
  fi

  _reject_flag_as_target "$arg"
  INPUT_MODE="target"
  TARGET="$arg"
  BASE="${HUNTING_HOME:-$HOME/hunting}/targets/$TARGET"
  LIVEFILE="$BASE/http/live.txt"
  [[ -f "$LIVEFILE" ]] || die "Ejecuta primero scope-v2 $TARGET"
}

resolve_input "${1:-}"

KATANA_DEPTH="${KATANA_DEPTH:-2}"
KATANA_CONCURRENCY="${KATANA_CONCURRENCY:-15}"
KATANA_PARALLELISM="${KATANA_PARALLELISM:-15}"
KATANA_TIMEOUT="${KATANA_TIMEOUT:-10}"
KATANA_RATE_LIMIT="${KATANA_RATE_LIMIT:-5}"

need_cmd katana anew grep jq
ensure_dir "$BASE/http" "$BASE/js" "$BASE/meta"

: > "$BASE/http/urls.txt"
: > "$BASE/http/urls_clean.txt"
: > "$BASE/http/api_candidates.txt"
: > "$BASE/http/graphql.txt"
: > "$BASE/js/files.txt"

run_or_explain katana \
  -list "$LIVEFILE" \
  -silent \
  -jc \
  -d "$KATANA_DEPTH" \
  -c "$KATANA_CONCURRENCY" \
  -p "$KATANA_PARALLELISM" \
  -timeout "$KATANA_TIMEOUT" \
  -rl "$KATANA_RATE_LIMIT" \
  -kf all \
  | tee "$BASE/http/katana.raw" \
  | {
      if command -v uro >/dev/null 2>&1; then
        uro
      else
        cat
      fi
    } \
  | anew "$BASE/http/urls.txt" >/dev/null

grep -Ei '\.js($|\?)' "$BASE/http/urls.txt" | anew "$BASE/js/files.txt" >/dev/null || true
grep -Ei '/api(/|$)|/v[0-9]+/|graphql|rest|swagger|openapi|/rpc(/|$)|/query($|[/?])|/mutation($|[/?])|/internal(/|$)' "$BASE/http/urls.txt" | anew "$BASE/http/api_candidates.txt" >/dev/null || true
grep -Ei 'graphql' "$BASE/http/urls.txt" | anew "$BASE/http/graphql.txt" >/dev/null || true
grep -Evi '\.(png|jpg|jpeg|gif|svg|css|woff|woff2|ttf|ico)($|\?)' "$BASE/http/urls.txt" > "$BASE/http/urls_clean.txt" || true

urls_count="$(count_lines_safe "$BASE/http/urls.txt")"
js_count="$(count_lines_safe "$BASE/js/files.txt")"
api_count="$(count_lines_safe "$BASE/http/api_candidates.txt")"

jq -n \
  --arg urls "$urls_count" \
  --arg js "$js_count" \
  --arg api "$api_count" \
  --arg mode "$INPUT_MODE" \
  --arg source "${INPUT_SOURCE:-$LIVEFILE}" \
  --arg depth "$KATANA_DEPTH" \
  --arg concurrency "$KATANA_CONCURRENCY" \
  --arg parallelism "$KATANA_PARALLELISM" \
  --arg timeout "$KATANA_TIMEOUT" \
  --arg rate_limit "$KATANA_RATE_LIMIT" \
  '{urls:($urls|tonumber), js:($js|tonumber), api_candidates:($api|tonumber), input_mode:$mode, input_source:$source, katana:{depth:($depth|tonumber), concurrency:($concurrency|tonumber), parallelism:($parallelism|tonumber), timeout:($timeout|tonumber), rate_limit:($rate_limit|tonumber)}}' \
  > "$BASE/meta/webmap.json"

log_ok "Modo: $INPUT_MODE"
log_ok "URLs totales: $urls_count"
log_ok "JS: $js_count"
log_ok "API candidates: $api_count"
log_ok "Raw crawl → $BASE/http/katana.raw"
log_ok "Katana limits: d=$KATANA_DEPTH c=$KATANA_CONCURRENCY p=$KATANA_PARALLELISM timeout=$KATANA_TIMEOUT rl=$KATANA_RATE_LIMIT"
