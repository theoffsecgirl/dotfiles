#!/usr/bin/env bash
# fuzzdirs — fuzz de directorios con ffuf
# Uso: fuzzdirs <url_base>
set -euo pipefail

[[ -z "${1:-}" ]] && { echo "Uso: fuzzdirs <url>"; exit 1; }

if [[ -z "${WORDLISTS:-}" ]]; then
  echo "[!] \$WORDLISTS no está definida. Exporta la variable antes de continuar."
  exit 1
fi

# Busca el wordlist en varias rutas conocidas
WORDLIST=""
for candidate in \
  "$WORDLISTS/dirsearch.txt" \
  "$WORDLISTS/fuzz4bounty/fuzz4bounty/dirsearch.txt" \
  "$WORDLISTS/dirb/common.txt" \
  "$WORDLISTS/Discovery/Web-Content/common.txt"
do
  if [[ -f "$candidate" ]]; then
    WORDLIST="$candidate"
    break
  fi
done

if [[ -z "$WORDLIST" ]]; then
  echo "[!] No se encontró ningún wordlist de directorios en \$WORDLISTS=$WORDLISTS"
  echo "    Rutas buscadas: dirsearch.txt, fuzz4bounty/dirsearch.txt, dirb/common.txt"
  exit 1
fi

echo "[*] Wordlist: $WORDLIST"
ffuf -u "${1%/}/FUZZ" -w "$WORDLIST" -mc all -fc 404 -c
