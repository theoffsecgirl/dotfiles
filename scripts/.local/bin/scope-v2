#!/usr/bin/env bash
# scope-v2 — recon inicial enriquecido: subdominios + hosts vivos + httpx JSONL
# Uso: scope-v2 <dominio>
set -euo pipefail

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=/dev/null
source "$SCRIPT_DIR/../lib/offsec.sh"

trap 'printf "[!] Error en linea %d — %s\n" "$LINENO" "$BASH_COMMAND" >&2
      printf "[!] Si falló una tool externa, revisa sus flags con -h o -version\n" >&2' ERR

case "${1:-}" in
  -h|--help)
    echo "Uso: scope-v2 <dominio>  (o usa el wrapper estable: scope <dominio>)"
    echo "  Subdominios + httpx JSONL + live.txt para un único dominio raíz."
    echo "  Siguiente paso: webmap <dominio>"
    exit 0 ;;
esac

[[ -z "${1:-}" ]] && { echo "Uso: scope-v2 <dominio>"; exit 1; }
_reject_flag_as_target "$1"

TARGET="$1"
BASE="${HUNTING_HOME:-$HOME/targets}/targets/$TARGET"
mkdir -p "$BASE"/{recon,http,meta,ai,tmp}

if command -v mktarget >/dev/null 2>&1; then
  mktarget "$TARGET" >/dev/null 2>&1 || true
fi

for dep in subfinder httpx anew jq; do
  command -v "$dep" >/dev/null 2>&1 || { echo "[!] Falta: $dep"; exit 1; }
done

echo "[*] Enumerando subdominios para $TARGET..."
run_or_explain subfinder -d "$TARGET" -silent -all -recursive \
  | sed 's/^\*\.//' | sort -u | anew "$BASE/recon/subdomains.txt" >/dev/null

SUB_COUNT=$(wc -l < "$BASE/recon/subdomains.txt" | tr -d ' ')
echo "[+] Subdominios: $SUB_COUNT"

echo "[*] Enriqueciendo hosts HTTP con httpx..."
run_or_explain httpx \
  -silent \
  -l "$BASE/recon/subdomains.txt" \
  -json \
  -title \
  -tech-detect \
  -status-code \
  -follow-redirects \
  -ip \
  -cdn \
  -ports 80,443,8080,8443 \
  | tee "$BASE/http/httpx.jsonl" \
  | jq -r 'select(.url != null) | .url' \
  | anew "$BASE/http/live.txt" >/dev/null

jq -r 'select(.url != null) | [.input, .url, (.status_code|tostring), (.webserver // ""), (.title // "")] | @tsv' "$BASE/http/httpx.jsonl" \
  > "$BASE/http/httpx_table.tsv"

jq -n \
  --arg target "$TARGET" \
  --arg generated_at "$(date -u +%FT%TZ)" \
  --arg sub_count "$SUB_COUNT" \
  --arg live_count "$(wc -l < "$BASE/http/live.txt" | tr -d ' ')" \
  '{target:$target, generated_at:$generated_at, subdomains:($sub_count|tonumber), live_hosts:($live_count|tonumber)}' \
  > "$BASE/meta/scope.json"

echo "[+] Hosts vivos: $(wc -l < "$BASE/http/live.txt" | tr -d ' ') → $BASE/http/live.txt"
echo "[+] httpx JSONL → $BASE/http/httpx.jsonl"
echo "[+] metadata → $BASE/meta/scope.json"
echo "[→] Siguiente paso: webmap $TARGET"
