#!/usr/bin/env python3
"""
program-import-brief — importa un brief pegado/exportado a un workspace de programa.

Uso:
  program-import-brief <programa> <brief.txt>

Genera/actualiza:
  in/program.md
  in/scope-web.txt
  in/out-of-scope.txt
  in/roots.txt
  in/brief.txt
  meta/brief-import.json
"""
from __future__ import annotations

import json
import os
import re
import shutil
import sys
from datetime import datetime, timezone
from pathlib import Path
from urllib.parse import urlparse


MULTIPART_PUBLIC_SUFFIXES = {
    "co.uk", "org.uk", "ac.uk", "gov.uk",
    "com.au", "net.au", "org.au",
    "com.br", "com.mx", "com.ar",
    "com.tr", "com.cn", "com.hk", "co.jp", "co.kr",
    "co.in", "com.sg", "com.my",
    "co.nz",
}


def die(msg: str, code: int = 1) -> None:
    print(f"[!] {msg}", file=sys.stderr)
    raise SystemExit(code)


def hunting_home() -> Path:
    return Path(os.environ.get(
        "HUNTING_HOME",
        str(Path.home() / "Library/Mobile Documents/com~apple~CloudDocs/02_PROFESIONAL/bugbounty"),
    )).expanduser()


def clean_line(line: str) -> str:
    return line.strip().strip("`'\"").strip()


def normalize_host(value: str) -> str:
    value = clean_line(value)
    if not value:
        return ""
    if value.startswith(("http://", "https://")):
        parsed = urlparse(value)
        value = parsed.netloc
    value = value.split("@")[-1]
    value = value.split(":")[0]
    return value.lower().strip().strip("/").strip(".")


def root_from_pattern(value: str) -> str:
    host = normalize_host(value)
    host = host.replace("*.", "").replace("*", "").strip(".")
    parts = [p for p in host.split(".") if p]
    if len(parts) < 2:
        return ""
    if parts[0] == "www" and len(parts) >= 3:
        parts = parts[1:]

    suffix2 = ".".join(parts[-2:])
    if suffix2 in MULTIPART_PUBLIC_SUFFIXES and len(parts) >= 3:
        return ".".join(parts[-3:])
    return ".".join(parts[-2:])


def unique(items: list[str]) -> list[str]:
    seen: set[str] = set()
    out: list[str] = []
    for item in items:
        item = clean_line(item)
        key = normalize_host(item) if re.search(r"https?://|\.", item) else item.lower()
        if not item or key in seen:
            continue
        seen.add(key)
        out.append(item)
    return out


def looks_like_heading(line: str) -> bool:
    stripped = line.strip()
    if not stripped:
        return False
    if stripped.startswith(("#", "##", "###")):
        return True
    if stripped.endswith(":") and len(stripped) <= 80:
        return True
    if re.match(r"^\s*\|?\s*(in[-\s]?scope|out[-\s]?of[-\s]?scope|scope|rules|known issues|exclusions|rewards)\b", stripped, re.I):
        return True
    return False


def extract_section(text: str, start_patterns: list[str], stop_patterns: list[str]) -> str:
    lines = text.splitlines()
    start = None
    start_re = re.compile("|".join(start_patterns), re.I)
    stop_re = re.compile("|".join(stop_patterns), re.I)

    for i, line in enumerate(lines):
        lower = line.lower().strip()
        if start_re.search(lower):
            start = i
            break
    if start is None:
        return ""

    end = len(lines)
    for j in range(start + 1, len(lines)):
        lower = lines[j].lower().strip()
        if stop_re.search(lower) and looks_like_heading(lines[j]):
            end = j
            break
    return "\n".join(lines[start:end])


def extract_urls_and_patterns(section: str) -> list[str]:
    values: list[str] = []
    url_re = re.compile(r"https?://[^\s)\]}>|]+", re.I)
    wildcard_re = re.compile(r"(?<![A-Za-z0-9_-])(?:[A-Za-z0-9_-]+\.)*\*\.[A-Za-z0-9_.-]+|(?<![A-Za-z0-9_-])(?:www\.)?[A-Za-z0-9_-]+\.[A-Za-z0-9_.-]*\*", re.I)
    host_re = re.compile(r"(?<![@/A-Za-z0-9_-])(?:www\.)?[A-Za-z0-9_-]+(?:\.[A-Za-z0-9_-]+)+(?=$|[\s,;)\]}>|])", re.I)

    values.extend(url_re.findall(section))
    values.extend(wildcard_re.findall(section))

    for host in host_re.findall(section):
        lower = host.lower().rstrip(".,;")
        if lower.endswith((".md", ".txt", ".png", ".jpg", ".jpeg", ".gif", ".pdf", ".json", ".yaml", ".yml")):
            continue
        if "@" in lower:
            continue
        values.append(host)

    cleaned = []
    for value in values:
        value = clean_line(value).rstrip(".,;")
        if value:
            cleaned.append(value)
    return unique(cleaned)


def host_matches_pattern(host: str, pattern: str) -> bool:
    h = normalize_host(host)
    p = normalize_host(pattern).replace("*.", "").replace("*", "").strip(".")
    if not h or not p:
        return False
    return h == p or h.endswith("." + p)


def collapse_wildcard_duplicates(values: list[str]) -> list[str]:
    wildcards = [normalize_host(v).replace("*.", "").strip(".") for v in values if "*" in v]
    out = []
    for v in values:
        hv = normalize_host(v)
        if "*" not in v and any(hv == w for w in wildcards):
            continue
        out.append(v)
    return unique(out)


def extract_rules(text: str) -> list[str]:
    interesting = []
    patterns = [
        "automated tools", "scanner", "rate limit", "user agent", "bugcrowd-",
        "customer data", "personally identifiable", "pii", "pivot",
        "post-exploitation", "own account", "safe harbor", "public disclosure",
        "social engineering", "phishing", "denial of service", "dos", "ddos",
    ]
    for raw in text.splitlines():
        line = clean_line(raw.lstrip("-•*0123456789. "))
        if not line:
            continue
        lower = line.lower()
        if any(p in lower for p in patterns):
            interesting.append(line)
    return unique(interesting)


def write_lines(path: Path, lines: list[str], header: str) -> None:
    body = [header, ""] + lines if lines else [header, "", "# TODO: rellenar manualmente"]
    path.write_text("\n".join(body).rstrip() + "\n", encoding="utf-8")


def main() -> int:
    if len(sys.argv) > 1 and sys.argv[1] in ("-h", "--help"):
        print("Uso: program-import-brief <programa> <brief.txt>")
        print("  Importa un brief de programa (H1/Bugcrowd/Intigriti) en el workspace.")
        print("  Genera: in/scope-web.txt, in/out-of-scope.txt, in/roots.txt, in/program.md")
        print("  Anterior: program-init <programa>   Siguiente: scope-program <programa>")
        return 0

    if len(sys.argv) != 3:
        die("Uso: program-import-brief <programa> <brief.txt>")

    program = sys.argv[1].strip()
    brief_file = Path(sys.argv[2]).expanduser()
    if not program:
        die("Programa vacío")
    if program.startswith("-"):
        die(f"Argumento inválido: '{program}' parece una flag, no un programa")
    if not brief_file.is_file():
        die(f"No existe el brief: {brief_file}")

    base = hunting_home() / "targets" / program
    in_dir = base / "in"
    meta_dir = base / "meta"
    notes_dir = base / "notes"
    for d in (in_dir, meta_dir, notes_dir):
        d.mkdir(parents=True, exist_ok=True)

    text = brief_file.read_text(encoding="utf-8", errors="replace")
    normalized = text.replace("\r\n", "\n").replace("\r", "\n")

    in_scope_section = extract_section(
        normalized,
        [
            r"\bin[-\s]?scope targets\b",
            r"\bin[-\s]?scope\b",
            r"\bscope and rewards\b",
            r"\bassets? in scope\b",
            r"\bwithin scope\b",
            r"\btargets? in scope\b",
            r"\bdentro de alcance\b",
            r"\ben alcance\b",
        ],
        [
            r"\bout[-\s]?of[-\s]?scope targets\b",
            r"\bout[-\s]?of[-\s]?scope\b",
            r"\bfuera de alcance\b",
            r"\bknown issues\b",
            r"\bthings to know\b",
            r"\brules\b",
            r"\bexclusions\b",
            r"\bnot eligible\b",
        ],
    )
    out_scope_section = extract_section(
        normalized,
        [
            r"\bout[-\s]?of[-\s]?scope targets\b",
            r"\bout[-\s]?of[-\s]?scope\b",
            r"\bfuera de alcance\b",
            r"\bexclusions\b",
        ],
        [
            r"\bknown issues\b",
            r"\bthings to know\b",
            r"\bvulnerabilities rewarded\b",
            r"\brules\b",
            r"\bpublic disclosure\b",
            r"\bsafe harbor\b",
            r"\bnot eligible\b",
        ],
    )

    in_scope = collapse_wildcard_duplicates(extract_urls_and_patterns(in_scope_section or normalized))
    out_scope = collapse_wildcard_duplicates(extract_urls_and_patterns(out_scope_section))

    # Evita que out-of-scope exacto o por wildcard/patrón acabe en scope-web.
    in_scope = [
        x for x in in_scope
        if not any(host_matches_pattern(x, o) or host_matches_pattern(o, x) for o in out_scope)
    ]

    roots = unique([r for r in (root_from_pattern(x) for x in in_scope) if r])
    rules = extract_rules(normalized)

    dst_brief = in_dir / "brief.txt"

    if brief_file.resolve() != dst_brief.resolve():
        shutil.copyfile(brief_file, dst_brief)
    
    write_lines(in_dir / "scope-web.txt", in_scope, "# In-scope web assets extracted from brief")
    write_lines(in_dir / "out-of-scope.txt", out_scope, "# Out-of-scope assets extracted from brief")
    write_lines(in_dir / "roots.txt", roots, "# Root domains inferred from in-scope web assets")

    program_md = [
        f"# {program} program notes",
        "",
        f"Imported at: {datetime.now(timezone.utc).strftime('%Y-%m-%dT%H:%M:%SZ')}",
        "",
        "## In-scope web",
        "",
        *(f"- {x}" for x in in_scope),
        "",
        "## Out of scope",
        "",
        *(f"- {x}" for x in out_scope),
        "",
        "## Inferred roots",
        "",
        *(f"- {x}" for x in roots),
        "",
        "## Important rules detected",
        "",
        *(f"- {x}" for x in rules),
        "",
        "## Recommended flow",
        "",
        "```bash",
        f'cd "$HUNTING_HOME/targets/{program}"',
        f"scope-program {program}",
        f"webmap {program}",
        f"paramhunt-v2 {program}",
        "```",
        "",
    ]
    (in_dir / "program.md").write_text("\n".join(program_md), encoding="utf-8")

    summary = notes_dir / "summary.md"
    if not summary.exists():
        summary.write_text(
            f"# {program} hunting notes\n\n"
            "## Scope summary\n\n"
            "## Recon summary\n\n"
            "## Interesting endpoints\n\n"
            "## Hypotheses\n"
            "- [ ] Auth/account logic\n"
            "- [ ] IDOR/authz\n"
            "- [ ] Redirects\n"
            "- [ ] Client-side issues\n"
            "- [ ] API behavior\n\n"
            "## Findings\n",
            encoding="utf-8",
        )

    meta = {
        "program": program,
        "imported_at": datetime.now(timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ"),
        "source": str(brief_file),
        "in_scope_count": len(in_scope),
        "out_of_scope_count": len(out_scope),
        "roots_count": len(roots),
        "rules_count": len(rules),
    }
    (meta_dir / "brief-import.json").write_text(json.dumps(meta, indent=2) + "\n", encoding="utf-8")

    print(f"[+] Importado brief para: {program}")
    print(f"[+] In-scope web: {len(in_scope)} → {in_dir / 'scope-web.txt'}")
    print(f"[+] Out-of-scope: {len(out_scope)} → {in_dir / 'out-of-scope.txt'}")
    print(f"[+] Roots: {len(roots)} → {in_dir / 'roots.txt'}")
    print(f"[+] Program notes → {in_dir / 'program.md'}")
    print("[→] Revisa manualmente los ficheros antes de lanzar recon")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
