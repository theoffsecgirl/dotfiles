#!/usr/bin/env bash
# offsec-bootstrap — enlaza scripts de dotfiles a ~/.local/bin de forma idempotente
set -euo pipefail

DOTFILES_DIR="${DOTFILES_DIR:-$HOME/.dotfiles}"
SRC_DIR="$DOTFILES_DIR/scripts/.local/bin"
BIN_DIR="$HOME/.local/bin"
BACKUP_DIR="$HOME/.local/share/dotfiles-backups"

mkdir -p "$BIN_DIR" "$BACKUP_DIR"

log()  { printf '\033[1;34m[*]\033[0m %s\n' "$*"; }
ok()   { printf '\033[1;32m[+]\033[0m %s\n' "$*"; }
warn() { printf '\033[1;33m[!]\033[0m %s\n' "$*"; }

[[ -d "$SRC_DIR" ]] || { echo "[x] No existe $SRC_DIR"; exit 1; }

link_one() {
  local src="$1"
  local name target cur
  name="$(basename "$src")"
  target="$BIN_DIR/$name"

  if [[ -L "$target" ]]; then
    cur="$(readlink "$target" || true)"
    if [[ "$cur" == "$src" ]]; then
      return 0
    fi
    mv "$target" "$BACKUP_DIR/${name}.bak.$(date +%s)"
  elif [[ -e "$target" ]]; then
    mv "$target" "$BACKUP_DIR/${name}.bak.$(date +%s)"
  fi

  ln -sf "$src" "$target"
}

for src in "$SRC_DIR"/*; do
  [[ -f "$src" ]] || continue
  link_one "$src"
done

find "$BIN_DIR" -maxdepth 1 -type l >/dev/null 2>&1 || true
hash -r 2>/dev/null || true
ok "Bootstrap completado: scripts enlazados en $BIN_DIR"
