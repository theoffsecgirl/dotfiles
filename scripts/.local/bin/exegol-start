#!/bin/bash
# Raycast Script para arrancar Exegol (tooling pesado)
# Required parameters:
# @raycast.schemaVersion 1
# @raycast.title Start Exegol
# @raycast.mode compact
# @raycast.packageName Bug Bounty
# @raycast.icon ⚡

set -e

# Verificar si Exegol está instalado
if ! command -v exegol &> /dev/null; then
    echo "❌ Exegol not installed."
    echo "Install: pipx install exegol"
    exit 1
fi

IMAGE="web"
CONTAINER="exegol-$IMAGE"

echo "🚀 Starting Exegol ($IMAGE)..."
exegol start "$CONTAINER" "$IMAGE" || exegol install "$IMAGE" && exegol start "$CONTAINER" "$IMAGE"

echo "✅ Exegol ready."
