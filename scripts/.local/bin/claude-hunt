#!/usr/bin/env bash
# claude-hunt — prepara y, opcionalmente, ejecuta un análisis de bug bounty con Claude Code
# Uso: claude-hunt [--run] <target>
set -euo pipefail

RUN=0
if [[ "${1:-}" == "--run" ]]; then
  RUN=1
  shift
fi

[[ -n "${1:-}" ]] || { echo "Uso: claude-hunt [--run] <target>"; exit 1; }

TARGET="$1"
BASE="${HUNTING_HOME:-$HOME/targets}/targets/$TARGET"
OUTDIR="$BASE/ai"
PROMPTFILE="$OUTDIR/hunt.prompt.md"
OUTFILE="$OUTDIR/hunt.json"
ERRFILE="$OUTDIR/hunt.claude.stderr.log"

[[ -d "$BASE" ]] || { echo "[ERR] Target no encontrado: $BASE" >&2; exit 1; }
mkdir -p "$OUTDIR"

section() {
  local rel="$1"
  local lines="${2:-200}"
  local abs="$BASE/$rel"

  printf '\n## FILE: %s\n\n' "$rel"
  if [[ -f "$abs" ]]; then
    sed -n "1,${lines}p" "$abs"
  else
    printf '[missing] %s\n' "$rel"
  fi
}

{
  cat <<EOF
# Análisis de bug bounty: $TARGET

Actúa como analista técnico. No confirmes vulnerabilidades sin evidencia.

Reglas:
- Respeta estrictamente in/scope-web.txt e in/out-of-scope.txt.
- No inventes endpoints, parámetros, roles ni impacto.
- No propongas recon ya cubierto por los artefactos existentes.
- Prioriza control de acceso, lógica de negocio, APIs y GraphQL.
- Distingue hipótesis de validación.
- Limita la salida a 5 hipótesis priorizadas.
- No ejecutes tráfico activo desde este análisis.

Devuelve SOLO JSON válido con este esquema:
{
  "target": "$TARGET",
  "summary": "",
  "priority_surfaces": [
    {
      "host": "",
      "endpoint_or_area": "",
      "why": "",
      "evidence": []
    }
  ],
  "hypotheses": [
    {
      "title": "",
      "class": "access-control | business-logic | graphql | ssrf | xss | other",
      "endpoint": "",
      "evidence": [],
      "preconditions": [],
      "manual_test": [],
      "expected_signal": "",
      "impact_if_confirmed": "",
      "confidence": "high | medium | low"
    }
  ],
  "missing_evidence": [],
  "next_manual_action": ""
}

# Dataset
EOF

  section "in/program.md" 250
  section "in/scope-web.txt" 250
  section "in/out-of-scope.txt" 250
  section "notes/summary.md" 300
  section "meta/scope-program.json" 200
  section "meta/scope.json" 200
  section "meta/webmap.json" 200
  section "meta/paramhunt.json" 200
  section "http/live.txt" 250
  section "http/httpx_table.tsv" 250
  section "http/api_candidates.txt" 250
  section "http/graphql.txt" 200
  section "js/files.txt" 250
  section "fuzz/sensitive_params.txt" 250
  section "fuzz/params_by_host.jsonl" 250
} > "$PROMPTFILE"

printf '[+] Prompt preparado: %s\n' "$PROMPTFILE"

if [[ "$RUN" -eq 0 ]]; then
  printf '[i] No se ha ejecutado Claude. Usa: claude-hunt --run %s\n' "$TARGET"
  exit 0
fi

command -v claude >/dev/null 2>&1 || {
  echo "[ERR] Claude Code no está disponible. El prompt queda guardado." >&2
  exit 1
}

if claude -p "$(cat "$PROMPTFILE")" >"$OUTFILE" 2>"$ERRFILE"; then
  if jq -e . "$OUTFILE" >/dev/null 2>&1; then
    printf '[+] Análisis guardado: %s\n' "$OUTFILE"
  else
    mv "$OUTFILE" "$OUTFILE.invalid"
    echo "[WARN] Claude respondió, pero no devolvió JSON válido." >&2
    echo "[WARN] Respuesta conservada en $OUTFILE.invalid" >&2
    exit 1
  fi
else
  rm -f "$OUTFILE"
  echo "[ERR] Claude falló. Revisa $ERRFILE" >&2
  exit 1
fi
