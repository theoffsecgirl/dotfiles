#!/usr/bin/env bash
# claude-recon-v2 — analiza outputs de recon con Claude Code y guarda prompt reutilizable
# Uso: claude-recon-v2 <dominio>
set -euo pipefail

[[ -z "${1:-}" ]] && { echo "Uso: claude-recon-v2 <dominio>"; exit 1; }

TARGET="$1"
BASE="${HUNTING_HOME:-$HOME/hunting}/targets/$TARGET"
OUTDIR="$BASE/ai"
PROMPTFILE="$OUTDIR/recon.prompt.txt"
OUTFILE="$OUTDIR/recon.json"
ERRFILE="$OUTDIR/recon.claude.stderr.log"

[[ -d "$BASE" ]] || { echo "[ERR] Target no encontrado: $BASE"; exit 1; }
mkdir -p "$OUTDIR"

section() {
  local rel="$1"
  local lines="${2:-200}"
  local abs="$BASE/$rel"
  echo "===== FILE: $rel ====="
  if [[ -f "$abs" ]]; then
    sed -n "1,${lines}p" "$abs"
  else
    echo "[missing] $rel"
  fi
  echo
}

{
  cat <<EOF
Analiza este dataset de recon de bug bounty para el target: $TARGET

Objetivo:
- identificar activos interesantes
- detectar superficies sensibles
- priorizar hosts
- sugerir vectores de ataque

Devuelve SOLO JSON válido con este esquema:
{
  "priority_hosts": [],
  "sensitive_flows": [],
  "attack_vectors": [],
  "notes": []
}

Dataset:
EOF
  section "http/live.txt" 200
  section "http/urls.txt" 200
  section "http/api_candidates.txt" 200
  section "js/files.txt" 200
  section "fuzz/params.txt" 200
  section "fuzz/sensitive_params.txt" 200
} > "$PROMPTFILE"

if ! command -v claude >/dev/null 2>&1; then
  echo "[WARN] claude no disponible. Prompt guardado en $PROMPTFILE"
  exit 0
fi

if claude -p "$(cat "$PROMPTFILE")" > "$OUTFILE" 2>"$ERRFILE"; then
  echo "[+] Claude recon analysis guardado en $OUTFILE"
  echo "[+] Prompt reutilizable → $PROMPTFILE"
else
  rm -f "$OUTFILE"
  echo "[WARN] Claude no devolvió resultado usable. Revisa $ERRFILE"
  echo "[+] Prompt reutilizable → $PROMPTFILE"
fi
