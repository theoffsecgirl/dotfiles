#!/usr/bin/env bash
# hunt-doctor — valida entorno host/contenedor y tooling
set -euo pipefail

ok()   { printf '\033[1;32m[OK]\033[0m   %s\n' "$1"; }
warn() { printf '\033[1;33m[WARN]\033[0m %s\n' "$1"; }
bad()  { printf '\033[1;31m[ERR]\033[0m  %s\n' "$1"; }
hdr()  { printf '\n\033[1m%s\033[0m\n' "$1"; }

_tool_ver() {
  local cmd="$1"
  local ver
  ver="$("$cmd" -version 2>&1 | grep -oE 'v?[0-9]+\.[0-9]+\.[0-9]+' | head -1 2>/dev/null)" \
    || ver="$("$cmd" --version 2>&1 | grep -oE 'v?[0-9]+\.[0-9]+\.[0-9]+' | head -1 2>/dev/null)" \
    || ver="?"
  printf '%s' "${ver:-?}"
}

check_tool() {
  local cmd="$1"
  if command -v "$cmd" >/dev/null 2>&1; then
    local ver
    ver="$(_tool_ver "$cmd")"
    ok "$cmd  ($ver)"
  else
    bad "$cmd  (no encontrado)"
  fi
}

check_script() {
  local s="$1"
  if command -v "$s" >/dev/null 2>&1; then
    ok "$s"
  else
    bad "$s  (no en PATH)"
  fi
}

hdr "Tools externas"
for t in subfinder httpx katana dnsx nuclei jq python3 unfurl anew; do
  check_tool "$t"
done

hdr "Scripts del pipeline"
for s in program-init program-import-brief scope-program scope-v2 webmap-v2 paramhunt-v2; do
  check_script "$s"
done

hdr "Wrappers estables"
for s in scope webmap; do
  check_script "$s"
done

hdr "IA para hunting"
check_script hunt-ai
if command -v claude >/dev/null 2>&1; then
  ok "claude  ($(claude --version 2>/dev/null | head -1))"
else
  warn "claude no instalado o sin acceso; hunt-ai --prompt-only seguirá funcionando"
fi

if command -v caido-mcp-server >/dev/null 2>&1; then
  ok "caido-mcp-server  ($(caido-mcp-server --version 2>/dev/null | head -1))"
else
  warn "caido-mcp-server no encontrado; hunt-ai caido no podrá consultar el historial"
fi

if command -v claude >/dev/null 2>&1; then
  if claude mcp get caido 2>/dev/null | grep -q 'Connected'; then
    ok "MCP caido conectado"
  else
    warn "MCP caido no conectado o no registrado"
  fi
fi

hdr "Utilidades"
for s in tmux-recon tmux-sessionizer hunt-doctor; do
  check_script "$s"
done

hdr "Scripts retirados"
_retired=(claude-recon claude-recon-v2 claude-hypotheses claude-hypotheses-v2 chatgpt-recon chatgpt-hypotheses)
_retired_found=0
for s in "${_retired[@]}"; do
  _path="$(command -v "$s" 2>/dev/null || true)"
  if [[ -n "$_path" ]]; then
    warn "$s aún en PATH → $_path"
    _retired_found=$((_retired_found + 1))
  fi
done
[[ $_retired_found -eq 0 ]] && ok "No quedan wrappers de IA retirados en PATH"

hdr "Herramientas opcionales (bbref)"
for t in uro dalfox gau waybackurls gowitness trufflehog subjs ffuf feroxbuster amass assetfinder subjack; do
  if command -v "$t" >/dev/null 2>&1; then
    ver="$(_tool_ver "$t")"
    ok "$t  ($ver)"
  else
    warn "$t  (no encontrado — opcional)"
  fi
done

exit 0
