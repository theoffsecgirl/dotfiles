#!/usr/bin/env bash
# hunt-doctor — valida entorno host/contendor y tooling
set -euo pipefail

ok()   { printf '\033[1;32m[OK]\033[0m %s\n' "$1"; }
warn() { printf '\033[1;33m[WARN]\033[0m %s\n' "$1"; }
bad()  { printf '\033[1;31m[ERR]\033[0m %s\n' "$1"; }

check() {
  local cmd="$1"
  if command -v "$cmd" >/dev/null 2>&1; then ok "$cmd"; else bad "$cmd"; fi
}

# core recon tools
for t in subfinder httpx katana unfurl jq python3; do
  check "$t"
done

# scripts
for s in scope-v2 webmap-v2 paramhunt-v2; do
  check "$s"
done

# claude awareness
if command -v claude >/dev/null 2>&1; then
  ok "claude"
else
  warn "claude (no instalado aquí; ejecutar wrappers en host)"
fi

exit 0
