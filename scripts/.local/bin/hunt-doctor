#!/usr/bin/env bash
# hunt-doctor — valida entorno host/contenedor y tooling
set -euo pipefail

ok()   { printf '\033[1;32m[OK]\033[0m   %s\n' "$1"; }
warn() { printf '\033[1;33m[WARN]\033[0m %s\n' "$1"; }
bad()  { printf '\033[1;31m[ERR]\033[0m  %s\n' "$1"; }
hdr()  { printf '\n\033[1m%s\033[0m\n' "$1"; }

# Extrae versión de una tool: prueba con -version y -V como fallback
_tool_ver() {
  local cmd="$1"
  local ver
  ver="$("$cmd" -version 2>&1 | grep -oE 'v?[0-9]+\.[0-9]+\.[0-9]+' | head -1 2>/dev/null)" \
    || ver="$("$cmd" --version 2>&1 | grep -oE 'v?[0-9]+\.[0-9]+\.[0-9]+' | head -1 2>/dev/null)" \
    || ver="?"
  printf '%s' "${ver:-?}"
}

check_tool() {
  local cmd="$1"
  if command -v "$cmd" >/dev/null 2>&1; then
    local ver
    ver="$(_tool_ver "$cmd")"
    ok "$cmd  ($ver)"
  else
    bad "$cmd  (no encontrado)"
  fi
}

check_script() {
  local s="$1"
  if command -v "$s" >/dev/null 2>&1; then
    ok "$s"
  else
    bad "$s  (no en PATH)"
  fi
}

# ── Tools externas ───────────────────────────────────────────────────────────
hdr "Tools externas"
for t in subfinder httpx katana dnsx nuclei jq python3 unfurl anew; do
  check_tool "$t"
done

# ── Scripts de pipeline ──────────────────────────────────────────────────────
hdr "Scripts del pipeline"
for s in program-init program-import-brief scope-program scope-v2 webmap-v2 paramhunt-v2; do
  check_script "$s"
done

# ── Wrappers estables ────────────────────────────────────────────────────────
hdr "Wrappers estables"
for s in scope webmap; do
  check_script "$s"
done

# ── Utilidades ───────────────────────────────────────────────────────────────
hdr "Utilidades"
for s in tmux-recon tmux-sessionizer hunt-doctor; do
  check_script "$s"
done

# ── Scripts deprecated en PATH ───────────────────────────────────────────────
hdr "Scripts deprecated"
_deprecated=(paramhunt claude-recon claude-hypotheses chatgpt-recon chatgpt-hypotheses)
_dep_found=0
for s in "${_deprecated[@]}"; do
  _path="$(command -v "$s" 2>/dev/null || true)"
  if [[ -n "$_path" ]]; then
    warn "$s aún en PATH → $_path  (debería ser solo un wrapper de aviso)"
    _dep_found=$((_dep_found + 1))
  fi
done
[[ $_dep_found -eq 0 ]] && ok "Ningún script deprecated detectado en PATH"

# ── claude ───────────────────────────────────────────────────────────────────
hdr "Claude Code"
if command -v claude >/dev/null 2>&1; then
  ok "claude"
else
  warn "claude  (no instalado en este entorno; ejecutar wrappers en el host)"
fi

exit 0
