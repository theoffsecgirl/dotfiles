# ~/.gitconfig (gestionado por stow desde theoffsecgirl/dotfiles)
# Los datos personales (name, email) van en ~/.gitconfig.local (NO versionado)

[core]
  excludesfile = ~/.gitignore_global
  editor       = nvim
  autocrlf     = input
  whitespace   = fix,trailing-space

[init]
  defaultBranch = main

[pull]
  rebase = true

[push]
  autoSetupRemote = true

[merge]
  conflictstyle = diff3

[diff]
  algorithm = histogram
  colorMoved = default

[color]
  ui = auto

[alias]
  st  = status
  co  = checkout
  br  = branch
  lg  = log --oneline --graph --decorate --all
  undo = reset --soft HEAD~1
  wip  = !git add -u && git commit -m 'wip'
  pushf = push --force-with-lease

# Identidad por defecto (personal) — aplica a todos los repos salvo override
# Crea con:
#   git config -f ~/.gitconfig.local user.name "Tu Nombre"
#   git config -f ~/.gitconfig.local user.email "tu@email.com"
[include]
  path = ~/.gitconfig.local

# Override por directorio — crea ~/.gitconfig.work con user.email de trabajo
[includeIf "gitdir:~/work/"]
  path = ~/.gitconfig.work
