# Ghostty config - OffSec setup

# Font
font-family = "JetBrainsMono Nerd Font"
font-size = 14
font-feature = -calt  # Disable ligatures si no te gustan

# Theme
theme = dark:catppuccin-mocha
background-opacity = 0.95
background-blur-radius = 20

# Window
window-padding-x = 8
window-padding-y = 8
window-decoration = true

# Cursor
cursor-style = block
cursor-style-blink = false

# Shell
shell-integration = detect
shell-integration-features = no-cursor,no-sudo

# Clipboard
clipboard-read = allow
clipboard-write = allow
clipboard-paste-protection = false

# Mouse
mouse-hide-while-typing = true

# Keybinds custom (estilo tmux)
keybind = super+t=new_tab
keybind = super+w=close_surface
keybind = super+shift+t=new_window
keybind = super+n=new_window
keybind = ctrl+shift+c=copy_to_clipboard
keybind = ctrl+shift+v=paste_from_clipboard

# Split vim-style (requiere ghostty > 1.0)
keybind = ctrl+shift+backslash=new_split:right
keybind = ctrl+shift+minus=new_split:down

# Quick access hunting
keybind = super+h=new_tab:~/hunting

# Performance
macos-non-native-fullscreen = false
macos-option-as-alt = true
