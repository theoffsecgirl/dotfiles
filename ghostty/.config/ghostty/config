# Ghostty config - OffSec setup

# Font
font-family = JetBrainsMono Nerd Font
font-size = 14

# Window
window-padding-x = 10
window-padding-y = 10
background-opacity = 1.0

# Colors - pastel pink/purple/green/blue
background = #1e1e2e
foreground = #cdd6f4
cursor-color = #f5c2e7
cursor-text = #1e1e2e
selection-background = #45475a
selection-foreground = #f5e0dc
minimum-contrast = 1.1

palette = 0=#45475a
palette = 1=#f38ba8
palette = 2=#a6e3a1
palette = 3=#f9e2af
palette = 4=#89b4fa
palette = 5=#cba6f7
palette = 6=#94e2d5
palette = 7=#bac2de
palette = 8=#585b70
palette = 9=#f2a0b3
palette = 10=#b7efb2
palette = 11=#fae8b9
palette = 12=#9dc1fb
palette = 13=#d7b8fa
palette = 14=#a8e8de
palette = 15=#dce0e8

# Cursor
cursor-style = block

# Shell
shell-integration = detect

# Clipboard
clipboard-read = allow
clipboard-write = allow

# Mouse
mouse-hide-while-typing = true

# macOS
macos-non-native-fullscreen = false
macos-option-as-alt = false

# Keybinds
keybind = cmd+t=new_tab
keybind = cmd+w=close_surface
keybind = cmd+n=new_window
keybind = cmd+d=new_split:right
keybind = cmd+shift+d=new_split:down
keybind = cmd+h=goto_split:left
keybind = cmd+j=goto_split:bottom
keybind = cmd+k=goto_split:top
keybind = cmd+l=goto_split:right
keybind = cmd+c=copy_to_clipboard
keybind = cmd+v=paste_from_clipboard
keybind = cmd+equal=increase_font_size:1
keybind = cmd+minus=decrease_font_size:1
keybind = cmd+0=reset_font_size
